{
  "name": "electron-hello",
  "version": "1.0.25",
  "main": "main/index.js",
  "scripts": {
    "build": "vite build",
    "start": "npm run build && electron .",
    "dev": "vite build --watch",
    "install:mac": "npm install --omit=optional",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:win": "npm run build && electron-builder --win portable --publish never",
    "dist:win:ci": "npm run build && electron-builder --win portable --publish always"
  },
  "build": {
    "appId": "com.receiptprinter.app",
    "productName": "Receipt Printer",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "main/**/*",
      "dist/**/*",
      "preload.js",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "Niravpatel129",
      "repo": "receipt-printer"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "22.3.27",
    "electron-reloader": "^1.2.3",
    "electron-builder": "^26.8.2",
    "vite": "^6.0.3"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "electron-updater": "^6.3.9",
    "node-thermal-printer": "^4.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "optionalDependencies": {
    "@thesusheer/electron-printer": "^2.0.4"
  }
}
